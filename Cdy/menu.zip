#!/bin/bash
# Color
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
LIGHT='\033[0;37m'
clear

yellow="\033[0;33m"
ungu="\033[0;35m"
Red="\033[91;1m"
Xark="\033[0m"
BlueCyan="\033[5;36m"
WhiteBe="\033[37m"
GreenBe="\033[5;32m"
YellowBe="\033[5;33m"
BlueBe="\033[5;34m"

# . Liner
function baris_panjang() {
  echo -e "\033[5;36m ———————————————————————————————————————————————\033[0m"
}

function ARI_Banner() {
  baris_panjang
  NAMASC="ARISCTUNNEL V4"
  function center_text() {
    local text="$1"
    local width=50
    local plain_text
    plain_text=$(echo -e "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local len=${#plain_text}
    local spaces=$(( (width - len) / 2 ))
    printf "%${spaces}s%s\033[0m\n" "" "$(echo -e "$text")"
  }
  formatted_text="\e[36m.::.\033[0;35m $NAMASC \e[36m.::."
  center_text "$formatted_text"
  baris_panjang
}

function Sc_Credit(){
  sleep 1
  baris_panjang
  function center_text() {
    local text="$1"
    local width=50
    local plain_text
    plain_text=$(echo -e "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local len=${#plain_text}
    local spaces=$(( (width - len) / 2 ))
    printf "%${spaces}s%s\033[0m\n" "" "$(echo -e "$text")"
  }
  formatted_text="\033[0;35m Terimakasih sudah menggunakan- \033[0m"
  formatted_text1="\033[0;35m Script Credit By $NAMASC \033[0m"
  center_text "$formatted_text"
  center_text "$formatted_text1"
  baris_panjang
  read -n 1 -s -r -p " Press Enter for Back to Manage"
  bash /usr/local/sbin/m-xray
}

duration=3
frames=("██10%" "█████35%" "█████████65%" "█████████████80%" "█████████████████████90%" "█████████████████████████100%")
num_frames=${#frames[@]}
num_iterations=$((duration))

Loading_Animasi() {
  for ((i = 0; i < num_iterations; i++)); do
    clear
    index=$((i % num_frames))
    color_code=$((31 + i % 7))
    echo ""
    echo ""
    echo ""
    echo -e "\e[1;${color_code}m ${frames[$index]}\e[0m"
    sleep 0.5
  done
}

loading() {
  local pid=$1
  local delay=0.1
  local spin='-\|/'

  while ps -p $pid > /dev/null; do
    local temp=${spin#?}
    printf "[%c] " "$spin"
    local spin=$temp${spin%"$temp"}
    sleep $delay
    printf "\b\b\b\b\b\b"
  done

  printf "    \b\b\b\b"
}

function Loading_Succes() {
  clear
  echo -e  "\033[5;32mSucces\033[0m"
  sleep 2
  clear
}

# =========================
#        DELETE VMESS
#  Marker: "### user exp"
# =========================

NUMBER_OF_CLIENTS=$(grep -c -E "^### " "/etc/xray/config.json")
if [[ ${NUMBER_OF_CLIENTS} == '0' ]]; then
  ARI_Banner
  baris_panjang
  echo ""
  echo -e "${Red}  VMESS User Kosong !! ${Xark} "
  echo ""
  baris_panjang
  read -p "Press any key to back on menu"
  menu
fi

clear
baris_panjang
echo -e "${ungu}         DELETE VMESS     ${Xark} "
baris_panjang
baris_panjang
echo "  User       Expired  " | lolcat
baris_panjang

# List user vmess dari config
grep -E "^### " "/etc/xray/config.json" | cut -d ' ' -f 2-3 | column -t | sort | uniq

echo ""
baris_panjang
echo ""
read -rp " Input Username    : " user

if [ -z "$user" ]; then
  sleep 3 & loading $!
  Loading_Succes
  menu
else
  # Ambil expiry dari config (biar sed range pas)
  exp=$(grep -wE "^### $user " "/etc/xray/config.json" | head -n 1 | awk '{print $3}')

  if [ -z "$exp" ]; then
    clear
    ARI_Banner
    baris_panjang
    echo -e "${Red}  Username Tidak Ditemukan !! ${Xark}"
    echo ""
    baris_panjang
    read -p "Press any key to back on menu"
    menu
  fi

  # Ambil uuid dari db vmess (kalau ada)
  # Format db diasumsikan: "### user exp uuid"
  uuid=$(grep -E "^###" "/etc/vmess/.vmess.db" 2>/dev/null | grep -wE "$user" | awk '{print $4}' | head -n 1)

  # Hapus blok user dari config.json
  sed -i "/^### $user $exp/,/^},{/d" /etc/xray/config.json

  # Simpan arsip ke userall (optional)
  echo "### $user $uuid" >> /etc/xray/.userall.db

  # Hapus dari db vmess (kalau kamu pakai)
  if [ -f /etc/vmess/.vmess.db ]; then
    sed -i "/^### $user $exp/,/^},{/d" /etc/vmess/.vmess.db
  fi

  # Hapus file user (sesuaikan kalau path beda)
  rm -rf /etc/vmess/"$user"
  rm -rf /etc/kyt/limit/vmess/ip 2>/dev/null
  rm -rf /var/www/html/vmess-"$user".txt 2>/dev/null

  systemctl restart xray > /dev/null 2>&1

  clear
  ARI_Banner
  baris_panjang
  echo -e "${GreenBe} Successfully ${Xark} "
  echo ""
  echo -e "${yellow} Client Name : $user ${Xark}"
  echo -e "${yellow} Expired On  : $exp  ${Xark}"
  echo ""
  baris_panjang
  Sc_Credit
fi
